<!--
  Linux Privilege Escalation Chain Detection
  MITRE ATT&CK: T1548.003 - Abuse Elevation Control Mechanism: Sudo and Sudo Caching
  Rule IDs: 100120-100124
  Deploy to: /var/ossec/etc/rules/local_rules.xml
-->

<group name="local,privilege_escalation,linux,">

  <!-- Sudo failure - wrong password or unauthorized user -->
  <rule id="100120" level="5">
    <if_sid>5401</if_sid>
    <match>NOT in sudoers|incorrect password attempt</match>
    <description>Sudo failure: user not in sudoers or wrong password</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <!-- Repeated sudo failures - possible priv esc attempt -->
  <rule id="100121" level="10" frequency="3" timeframe="120">
    <if_matched_sid>100120</if_matched_sid>
    <same_source_ip />
    <description>Repeated sudo failures from $(srcuser) - possible privilege escalation attempt</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>priv_esc_attempt,</group>
  </rule>

  <!-- SUID binary execution from non-standard path -->
  <rule id="100122" level="12">
    <if_sid>80700</if_sid>
    <regex>COMMAND=.*(\/tmp\/|\/dev\/shm\/|\/var\/tmp\/)</regex>
    <description>Suspicious SUID execution from writable directory - possible priv esc</description>
    <mitre>
      <id>T1548.001</id>
    </mitre>
    <group>suid_abuse,</group>
  </rule>

  <!-- /etc/passwd or /etc/shadow modification -->
  <rule id="100123" level="14">
    <if_sid>550</if_sid>
    <match>/etc/passwd|/etc/shadow</match>
    <description>Critical auth file modified: possible privilege escalation or persistence</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
    <group>critical_file_mod,</group>
  </rule>

  <!-- Kernel module loaded - potential rootkit -->
  <rule id="100124" level="13">
    <if_sid>80700</if_sid>
    <match>insmod |modprobe </match>
    <description>Kernel module loaded - investigate for rootkit or unauthorized driver</description>
    <mitre>
      <id>T1547.006</id>
    </mitre>
    <group>rootkit,</group>
  </rule>

</group>
