<!--
  SSH Brute Force Correlation Rules
  MITRE ATT&CK: T1110.001 - Brute Force: Password Guessing
  Rule IDs: 100100-100103
  Deploy to: /var/ossec/etc/rules/local_rules.xml
-->

<group name="local,sshd,authentication_failures,">

  <!-- Single SSH authentication failure (baseline) -->
  <rule id="100100" level="3">
    <if_sid>5710</if_sid>
    <description>SSH authentication failure from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- 5 SSH failures in 90 seconds from same source - likely brute force -->
  <rule id="100101" level="10" frequency="5" timeframe="90">
    <if_matched_sid>100100</if_matched_sid>
    <same_source_ip />
    <description>SSH brute force attempt: 5+ failures in 90s from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>brute_force,</group>
  </rule>

  <!-- 20 SSH failures in 120 seconds - automated tooling -->
  <rule id="100102" level="13" frequency="20" timeframe="120">
    <if_matched_sid>100100</if_matched_sid>
    <same_source_ip />
    <description>Automated SSH brute force: 20+ failures in 120s from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>brute_force,automated,</group>
  </rule>

  <!-- Successful SSH login from an IP that triggered brute force -->
  <rule id="100103" level="14">
    <if_sid>5715</if_sid>
    <same_source_ip />
    <description>SSH login success from brute force source $(srcip) - possible credential compromise</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>credential_compromise,</group>
  </rule>

</group>
